rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get club document
    function getClub(clubId) {
      return get(/databases/$(database)/documents/clubs/$(clubId));
    }
    
    // Helper function to get team document
    function getTeam(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId));
    }
    
    // Helper function to check if user is club owner
    function isClubOwner(clubId) {
      return isAuthenticated() && getClub(clubId).data.ownerId == request.auth.uid;
    }
    
    // Helper function to check if user is team coach (ownerId in teams collection)
    function isTeamCoach(teamId) {
      return isAuthenticated() && getTeam(teamId).data.ownerId == request.auth.uid;
    }
    
    // Helper function to check if user is "Presidente" of the club linked to a team
    function isPresidenteOfTeamClub(teamId) {
      let team = getTeam(teamId);
      // Check if team has a clubId
      if (!('clubId' in team.data) || team.data.clubId == null) {
        return false;
      }
      // Check if user is a club member with role "Presidente"
      let clubId = team.data.clubId;
      let memberPath = /databases/$(database)/documents/clubMembers/$(request.auth.uid + '_' + clubId);
      if (!exists(memberPath)) {
        return false;
      }
      let memberDoc = get(memberPath);
      return memberDoc.data.role == "Presidente";
    }
    
    // Clubs collection rules
    match /clubs/{clubId} {
      // Allow read if user is the owner or a member of the club
      allow read: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid ||
        exists(/databases/$(database)/documents/clubMembers/$(request.auth.uid + '_' + clubId))
      );
      
      // Allow create if user is authenticated and sets themselves as owner
      allow create: if isAuthenticated() && 
        request.resource.data.ownerId == request.auth.uid;
      
      // Allow update/delete only by the owner (ownerId)
      allow update, delete: if isAuthenticated() && 
        resource.data.ownerId == request.auth.uid;
    }
    
    // ClubMembers collection rules
    match /clubMembers/{memberId} {
      // Allow read if user is the member or the club owner
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isClubOwner(resource.data.clubId)
      );
      
      // Allow create/update/delete only by club owner
      allow create, update, delete: if isAuthenticated() && 
        isClubOwner(request.resource.data.clubId);
    }
    
    // Teams collection rules
    match /teams/{teamId} {
      // Allow read if:
      // - User is the team owner (ownerId)
      // - OR User is the team coach (coachId - stored in ownerId field)
      // - OR User is "Presidente" of the club the team belongs to
      allow read: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid ||
        isPresidenteOfTeamClub(teamId)
      );
      
      // Allow create if user is authenticated and sets themselves as owner
      allow create: if isAuthenticated() && 
        request.resource.data.ownerId == request.auth.uid;
      
      // Allow update/delete only by the team coach (ownerId field represents coachId)
      allow update, delete: if isAuthenticated() && 
        resource.data.ownerId == request.auth.uid;
    }
    
    // Players collection rules
    match /players/{playerId} {
      // Allow read if:
      // - User is the coach of the team (ownerId of the team)
      // - OR User is "Presidente" of the club the team belongs to
      allow read: if isAuthenticated() && (
        isTeamCoach(resource.data.teamId) ||
        isPresidenteOfTeamClub(resource.data.teamId)
      );
      
      // Allow create if user is the coach of the team
      allow create: if isAuthenticated() && 
        isTeamCoach(request.resource.data.teamId);
      
      // Allow update/delete only by the team coach
      allow update, delete: if isAuthenticated() && 
        isTeamCoach(resource.data.teamId);
    }
    
    // Matches collection rules
    match /matches/{matchId} {
      // Allow read if:
      // - User is the coach of the team (ownerId of the team)
      // - OR User is "Presidente" of the club the team belongs to
      allow read: if isAuthenticated() && (
        isTeamCoach(resource.data.teamId) ||
        isPresidenteOfTeamClub(resource.data.teamId)
      );
      
      // Allow create if user is the coach of the team
      allow create: if isAuthenticated() && 
        isTeamCoach(request.resource.data.teamId);
      
      // Allow update/delete only by the team coach
      allow update, delete: if isAuthenticated() && 
        isTeamCoach(resource.data.teamId);
    }
    
    // Statistics subcollections (playerStats, matchStats, teamStats, etc.)
    // These follow the same pattern as their parent collections
    match /teams/{teamId}/teamStats/{statId} {
      allow read: if isAuthenticated() && (
        isTeamCoach(teamId) ||
        isPresidenteOfTeamClub(teamId)
      );
      
      allow create, update, delete: if isAuthenticated() && 
        isTeamCoach(teamId);
    }
    
    match /players/{playerId}/playerStats/{statId} {
      allow read: if isAuthenticated() && (
        isTeamCoach(get(/databases/$(database)/documents/players/$(playerId)).data.teamId) ||
        isPresidenteOfTeamClub(get(/databases/$(database)/documents/players/$(playerId)).data.teamId)
      );
      
      allow create, update, delete: if isAuthenticated() && 
        isTeamCoach(get(/databases/$(database)/documents/players/$(playerId)).data.teamId);
    }
    
    match /matches/{matchId}/matchStats/{statId} {
      allow read: if isAuthenticated() && (
        isTeamCoach(get(/databases/$(database)/documents/matches/$(matchId)).data.teamId) ||
        isPresidenteOfTeamClub(get(/databases/$(database)/documents/matches/$(matchId)).data.teamId)
      );
      
      allow create, update, delete: if isAuthenticated() && 
        isTeamCoach(get(/databases/$(database)/documents/matches/$(matchId)).data.teamId);
    }
    
    // Match-related subcollections (substitutions, timelineEvents, etc.)
    match /matches/{matchId}/{document=**} {
      allow read: if isAuthenticated() && (
        isTeamCoach(get(/databases/$(database)/documents/matches/$(matchId)).data.teamId) ||
        isPresidenteOfTeamClub(get(/databases/$(database)/documents/matches/$(matchId)).data.teamId)
      );
      
      allow write: if isAuthenticated() && 
        isTeamCoach(get(/databases/$(database)/documents/matches/$(matchId)).data.teamId);
    }
  }
}
