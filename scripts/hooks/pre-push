#!/bin/bash
# Pre-push hook: runs ktlint + tests + coverage locally, then auto-bumps versionCode on release/* branches.
# Install with: bash scripts/install-hooks.sh

COVERAGE_MINIMUM=80

# Skip if this push was triggered by the hook itself
if [ -n "$VERSION_BUMP_IN_PROGRESS" ]; then
  exit 0
fi

# Skip delete operations — local sha is all zeros when deleting a remote ref
while read local_ref local_sha remote_ref remote_sha; do
  if [[ "$local_sha" == "0000000000000000000000000000000000000000" ]]; then
    exit 0
  fi
done

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

# Only run on release/* branches
if [[ ! "$BRANCH" =~ ^release/ ]]; then
  exit 0
fi

# Extract versionName from branch name (release/0.3.0 → 0.3.0)
VERSION_NAME="${BRANCH#release/}"

# Validate semver format
if [[ ! "$VERSION_NAME" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "⚠️  Branch '$BRANCH' doesn't match release/X.Y.Z — skipping version bump"
  exit 0
fi

# Check for [skip-tests] flag in the latest commit
PREV_MSG=$(git log -1 --format=%s HEAD)
SKIP_FLAG=""
if [[ "$PREV_MSG" == *"[skip-tests]"* ]]; then
  SKIP_FLAG=" [skip-tests]"
  echo "⏩ [skip-tests] detected — skipping local tests, lint and coverage"
else
  # ── 1. ktlint ──────────────────────────────────────────────────────────────
  echo "🔍 Running ktlint..."
  ./gradlew ktlintCheck --no-daemon -q 2>&1
  LINT_EXIT=$?

  if [ $LINT_EXIT -ne 0 ]; then
    echo "⚠️  ktlint issues found — running ktlintFormat to auto-fix..."
    ./gradlew ktlintFormat --no-daemon -q 2>&1
    git add -A
    git commit -m "style: ktlint auto-format"
    echo "✅ ktlint issues fixed and committed"
  else
    echo "✅ ktlint OK"
  fi

  # ── 2. Tests + Coverage ────────────────────────────────────────────────────
  echo "🧪 Running tests and coverage..."
  ./gradlew testDebugUnitTestCoverage --no-daemon -q 2>&1
  TEST_EXIT=$?

  if [ $TEST_EXIT -ne 0 ]; then
    echo "❌ Tests failed — fix them before pushing."
    echo "   To skip in CI only: add [skip-tests] to your commit message"
    exit 1
  fi

  echo "✅ Tests passed"

  # ── 3. Coverage threshold check ────────────────────────────────────────────
  COVERAGE_XML="build/reports/jacoco/testDebugUnitTestCoverage/coverage.xml"
  if [ -f "$COVERAGE_XML" ]; then
    COVERAGE=$(python3 - "$COVERAGE_XML" <<'EOF'
import sys, xml.etree.ElementTree as ET
tree = ET.parse(sys.argv[1])
root = tree.getroot()
for counter in root.findall('counter'):
    if counter.get('type') == 'INSTRUCTION':
        missed  = int(counter.get('missed',  0))
        covered = int(counter.get('covered', 0))
        total   = missed + covered
        print(f"{covered / total * 100:.1f}" if total > 0 else "0.0")
        break
EOF
)
    echo "📊 Overall instruction coverage: ${COVERAGE}%"
    PASSES=$(python3 -c "print('yes' if float('$COVERAGE') >= $COVERAGE_MINIMUM else 'no')")
    if [ "$PASSES" = "no" ]; then
      echo "❌ Coverage ${COVERAGE}% is below the required ${COVERAGE_MINIMUM}%"
      echo "   Add tests to reach the threshold or use [skip-tests] to bypass."
      exit 1
    fi
    echo "✅ Coverage OK (${COVERAGE}% ≥ ${COVERAGE_MINIMUM}%)"
  else
    echo "⚠️  Coverage report not found — skipping threshold check"
  fi
fi

# ── 4. versionCode bump ────────────────────────────────────────────────────
CURRENT_CODE=$(grep 'versionCode' app/build.gradle.kts | grep -oE '[0-9]+' | head -1)
if [ -z "$CURRENT_CODE" ]; then
  echo "❌ Could not read versionCode from app/build.gradle.kts"
  exit 1
fi
NEW_CODE=$((CURRENT_CODE + 1))

echo "🔢 Bumping versionCode $CURRENT_CODE → $NEW_CODE (v$VERSION_NAME)"

# Update Android
sed -i '' "s/versionCode = $CURRENT_CODE/versionCode = $NEW_CODE/" app/build.gradle.kts
sed -i '' "s/versionName = \"[^\"]*\"/versionName = \"$VERSION_NAME\"/" app/build.gradle.kts

# Update iOS
sed -i '' \
  "s/CURRENT_PROJECT_VERSION = [0-9]*;/CURRENT_PROJECT_VERSION = $NEW_CODE;/g" \
  iosApp/iosApp.xcodeproj/project.pbxproj
sed -i '' \
  "s/MARKETING_VERSION = [^;]*;/MARKETING_VERSION = $VERSION_NAME;/g" \
  iosApp/iosApp.xcodeproj/project.pbxproj

# Commit the bump
git add app/build.gradle.kts iosApp/iosApp.xcodeproj/project.pbxproj
git commit -m "chore: bump version to $VERSION_NAME (build $NEW_CODE)$SKIP_FLAG"

echo "✅ Version bumped and committed — pushing v$VERSION_NAME (build $NEW_CODE)"

# Push and cancel the original push (already handled here)
export VERSION_BUMP_IN_PROGRESS=1
git push origin HEAD
exit 1