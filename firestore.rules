rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =======================================================================
    // HELPER FUNCTIONS
    // =======================================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function getClub(clubId) {
      return get(/databases/$(database)/documents/clubs/$(clubId));
    }

    function getTeam(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId));
    }

    function userIsTeamOwner(teamId) {
      return isAuthenticated() && getTeam(teamId).data.assignedCoachId == request.auth.uid;
    }

    function isClubOwner(clubId) {
      return isAuthenticated() && getClub(clubId).data.ownerId == request.auth.uid;
    }

    function getTeamClubId(teamId) {
      let teamData = getTeam(teamId).data;
      return ('clubId' in teamData) ? teamData.clubId : null;
    }

    function isPresidenteOfClub(clubId) {
      let memberPath = /databases/$(database)/documents/clubMembers/$(request.auth.uid + '_' + clubId);
      return clubId != null &&
             exists(memberPath) &&
             ('Presidente' in get(memberPath).data.roles);
    }

    // =======================================================================
    // CLUBS AND CLUB MEMBERS
    // =======================================================================

    match /clubs/{clubId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.ownerId == request.auth.uid;

      allow update, delete: if isAuthenticated() &&
        resource.data.ownerId == request.auth.uid;
    }

    match /clubMembers/{memberId} {
      allow read: if isAuthenticated() && (
        resource == null ||
        resource.data.userId == request.auth.uid ||
        isClubOwner(resource.data.clubId) ||
        isPresidenteOfClub(resource.data.clubId)
      );

      allow create: if isAuthenticated() && (
        isClubOwner(request.resource.data.clubId) || (
          request.resource.data.userId == request.auth.uid &&
          memberId == request.auth.uid + '_' + request.resource.data.clubId &&
          exists(/databases/$(database)/documents/clubs/$(request.resource.data.clubId))
        )
      );

      allow update: if isAuthenticated() && (
        isClubOwner(resource.data.clubId) || (
          isPresidenteOfClub(resource.data.clubId) &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['roles'])
        )
      );

      allow delete: if isAuthenticated() && isClubOwner(resource.data.clubId);
    }

    // =======================================================================
    // TEAMS
    // =======================================================================

    match /teams/{teamId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() && (
        request.resource.data.assignedCoachId == request.auth.uid || (
          'clubId' in request.resource.data &&
          request.resource.data.clubId != null &&
          isPresidenteOfClub(request.resource.data.clubId)
        )
      );

      allow update: if isAuthenticated() && (
        resource.data.assignedCoachId == request.auth.uid || (
          getTeamClubId(teamId) != null &&
          isPresidenteOfClub(getTeamClubId(teamId)) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assignedCoachId', 'pendingCoachEmail'])
        )
      );

      allow delete: if isAuthenticated() &&
        resource.data.assignedCoachId == request.auth.uid;
    }

    // =======================================================================
    // PLAYERS AND MATCHES (Team-based permissions)
    // =======================================================================

    match /players/{playerId} {
      allow read: if isAuthenticated();
      allow create, update: if userIsTeamOwner(request.resource.data.teamId);
      allow delete: if userIsTeamOwner(resource.data.teamId);
    }

    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow create, update: if userIsTeamOwner(request.resource.data.teamId);
      allow delete: if userIsTeamOwner(resource.data.teamId);
    }

    // =======================================================================
    // MATCH OPERATIONS AND STATS
    // =======================================================================

    match /matchOperations/{operationId} {
      allow read: if isAuthenticated();
      allow create, update: if userIsTeamOwner(request.resource.data.teamId);
    }

    match /goals/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if userIsTeamOwner(request.resource.data.teamId);
    }

    match /substitutions/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if userIsTeamOwner(request.resource.data.teamId);
    }

    match /playerTimeHistory/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if userIsTeamOwner(request.resource.data.teamId);
    }

    match /playerTimes/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if userIsTeamOwner(request.resource.data.teamId);
      allow delete: if userIsTeamOwner(resource.data.teamId);
    }

    // =======================================================================
    // SUBCOLLECTIONS
    // =======================================================================

    match /teams/{teamId}/teamStats/{statId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if userIsTeamOwner(teamId);
    }

    match /players/{playerId}/playerStats/{statId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if userIsTeamOwner(get(/databases/$(database)/documents/players/$(playerId)).data.teamId);
    }

    match /matches/{matchId}/matchStats/{statId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if userIsTeamOwner(get(/databases/$(database)/documents/matches/$(matchId)).data.teamId);
    }

    match /matches/{matchId}/{document=**} {
      allow read: if isAuthenticated();
      allow write: if userIsTeamOwner(get(/databases/$(database)/documents/matches/$(matchId)).data.teamId);
    }

    // =======================================================================
    // PENDING COACH ASSIGNMENTS
    // =======================================================================

    match /pendingCoachAssignments/{teamId} {
      // Any authenticated user can read (needed for login-time self-resolution)
      allow read: if isAuthenticated();

      // Only Presidents of the team's club can create/update/delete pending assignments
      allow create, update, delete: if isAuthenticated() &&
        getTeamClubId(teamId) != null &&
        isPresidenteOfClub(getTeamClubId(teamId));
    }

    // =======================================================================
    // PRESIDENT NOTIFICATIONS
    // =======================================================================

    match /presidentNotifications/{clubId}/notifications/{notifId} {
      // Any club member can create a notification for the president
      // (e.g. a new user notifying the president they are waiting for team assignment)
      allow create: if isAuthenticated() &&
        exists(/databases/$(database)/documents/clubMembers/$(request.auth.uid + '_' + clubId));

      // Only the president can read, update (mark read/unread) and delete
      allow read, update, delete: if isAuthenticated() && isPresidenteOfClub(clubId);
    }

    // =======================================================================
    // FCM TOKENS
    // =======================================================================

    match /fcmTokens/{tokenId} {
      // Any authenticated user can read (needed for cross-user device cleanup:
      // SyncFcmTokenUseCase queries all docs with the same device token to
      // remove subscriptions belonging to previous users on the same device).
      allow read: if isAuthenticated();

      // Only the token owner can write their own doc.
      allow create, update: if isAuthenticated() &&
        request.auth.uid == request.resource.data.userId;

      // Any authenticated user can delete (needed for device cleanup: the
      // current user deletes stale docs that belong to previous users).
      allow delete: if isAuthenticated();
    }

    // =======================================================================
    // USERS
    // =======================================================================

    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
