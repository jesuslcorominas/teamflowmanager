{
  "name": "teamflowmanager-firestore-tests",
  "version": "1.0.0",
  "description": "Firestore security rules tests for TeamFlow Manager",
  "scripts": {
    "test": "mocha --exit",
    "test:watch": "mocha --watch --exit",
    "emulator:start": "firebase emulators:start --only firestore",
    "emulator:test": "firebase emulators:exec --only firestore 'npm test'"
  },
  "keywords": [
    "firestore",
    "security",
    "rules",
    "testing"
  ],
  "author": "TeamFlow Manager",
  "license": "MIT",
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.2",
    "firebase-tools": "^13.0.0",
    "mocha": "^10.2.0"
  }
}
